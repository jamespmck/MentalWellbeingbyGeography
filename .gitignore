# MentalWellbeingByGeography ignore rules

# Python / environment
__pycache__/
*.py[cod]
.venv/
venv/
env/
.env
.env.*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs
*.log
logs/
outputs/logs/

# Archives and quarantine
data/archive/
data/_quarantine/
outputs/archive/
docs/archive/

# Temporary/cache folders
tmp/
temp/
cache/
.cache/
*.tmp

# Keep active data, docs, scripts and audits trackable
!data/
!data/raw/
!data/processed/
!docs/
!scripts/
!outputs/
!outputs/audits/

# Extracted raw working folders - reproducible from source archives
data/raw/**/extracted/
data/raw/**/.extracted/
data/raw/**/*_extracted/
